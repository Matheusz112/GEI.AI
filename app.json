{
  "expo": {
    "name": "GEI.AI",
    "slug": "cordeiro",
    "version": "5.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#060B18"
    },
    "extra": {
      "eas": {
        "projectId": "73cce3af-c9c5-4521-9d91-c284184659df"
      }
    },
    "android": {
      "package": "com.geiaicordeiro.app",
      "versionCode": 50,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ]
    },
    "plugins": [
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Permitir que o GEI.AI use o microfone para comandos de voz e cadastro por voz.",
          "speechRecognitionPermission": "Permitir que o GEI.AI reconheça sua fala."
        }
      ]
    ],
    "platforms": ["ios", "android"]
  }
}
