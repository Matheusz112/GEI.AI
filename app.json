        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#060B18"
      }
    },
    "plugins": [
      "expo-camera",
      "expo-secure-store",
      "expo-navigation-bar"
    ],
    "sdkVersion": "54.0.0",
    "platforms": [
      "ios",
      "android"
    ]
  }
