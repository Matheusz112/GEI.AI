{
  "expo": {
    "name": "gei-gestao-estoque",
    "slug": "gei-gestao-estoque",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.seuempresa.geigestaoestoque"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#000000"
      },
      "package": "com.seuempresa.geigestaoestoque",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.USE_BIOMETRIC",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/logo.png"
    },
    "plugins": [
      "expo-local-authentication",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "O GEI.IA precisa de acesso à câmera para ler códigos de barras."
        }
      ]
    ]
  }
}
